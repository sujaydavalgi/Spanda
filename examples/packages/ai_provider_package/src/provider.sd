module spanda_openai;

import std.ai;
extern python fn openai_complete(prompt: String) -> String;

// OpenAI provider package demo.
// Uses the bridge-backed ai.openai.complete(prompt) helper.

robot OpenAIAgent {
  actuator wheels: DifferentialDrive;

  behavior reason() {
    let plan = openai_complete("Plan a safe path around obstacles");
    let _ = plan;
    wheels.stop();
  }
}
