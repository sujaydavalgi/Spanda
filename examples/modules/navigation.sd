// Navigation robot — pairs with `path_planning.sd` (export module checked separately).
module navigation;

import std.spatial;

robot Navigator {
  sensor lidar: Lidar on "/scan";
  actuator drive: DifferentialDrive;

  behavior run() {
    let start = pose(x: 0.0 m, y: 0.0 m, theta: 0.0 rad);
    let goal = pose(x: 3.0 m, y: 1.0 m, theta: 0.0 rad);
    let route = trajectory(from: start, to: goal, steps: 8);
    let _ = route;
    drive.stop();
  }
}
