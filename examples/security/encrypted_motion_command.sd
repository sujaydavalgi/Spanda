robot MotionBot {
  trust trusted;

  permissions [
    crypto.encrypt,
    crypto.sign,
    crypto.verify,
    identity.sign,
    identity.verify,
    secret.read,
    secure_topic.publish
  ];

  secrets {
    motion_key from env "MOTION_SESSION_KEY";
  }

  identity RoverIdentity {
    id: "motion-bot";
    public_key: "pub-motion";
  }

  trust_boundary robot_to_robot;

  topic motion_cmd: SafeAction publish on "/motion" secure {
    encryption required;
    signed required;
    trusted_sources [PlannerAgent];
    reject_untrusted true;
  };

  agent PlannerAgent {
    uses planner;
    tools [];
    goal "Plan motion";
    can [ publish(motion_cmd), plan ];

    plan {
      let proposal: ActionProposal = planner.reason(prompt: "forward");
      let action: SafeAction = safety.validate(proposal);
      publish motion_cmd with action;
    }
  }

  ai_model planner: LLM { provider: "mock"; model: "test"; temperature: 0.1; }
  safety { max_speed = 1.0 m/s; }

  behavior run() {
    PlannerAgent.plan();
  }
}
