robot EncryptedLidar {
  trust trusted;

  permissions [
    crypto.encrypt,
    crypto.decrypt,
    identity.sign,
    identity.verify,
    secret.read,
    secure_topic.publish,
    secure_topic.subscribe
  ];

  secrets {
    session_key from env "LIDAR_SESSION_KEY";
  }

  identity RoverIdentity {
    id: "rover-lidar-01";
    public_key: "pub-lidar-01";
  }

  secure_comm {
    encryption: required;
    authentication: signed;
    integrity: required;
  }

  trust_boundary robot_internal;

  topic lidar_scan: LidarScan publish on "/scan" secure {
    encryption required;
    signed required;
    trusted_sources [RoverIdentity];
  };

  sensor lidar_front: Lidar on "/scan";

  behavior run() {
    let scan = lidar_front.read();
    publish lidar_scan with scan;
  }
}
