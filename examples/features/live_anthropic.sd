// Feature: live Anthropic ai_model provider (mock fallback without ANTHROPIC_API_KEY)
//
//   spanda check examples/features/live_anthropic.sd
//   ANTHROPIC_API_KEY=sk-ant-... spanda run examples/features/live_anthropic.sd
//
// Docs: docs/live-ai-provider.md

robot LiveAnthropic {
    sensor lidar: Lidar on "/scan";
    ai_model planner: LLM {
        provider: "anthropic";
        model: "claude-3-5-haiku-20241022";
    }
    actuator wheels: DifferentialDrive;

    safety {
        max_speed = 1.0 m/s;
    }

    behavior run() {
        let scan = lidar.read();
        let proposal = planner.reason(prompt: "Plan a safe stop", input: scan);
        let action = safety.validate(proposal);
        wheels.execute(action);
    }
}
