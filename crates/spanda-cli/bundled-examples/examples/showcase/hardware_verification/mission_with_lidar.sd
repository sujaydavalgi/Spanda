// Same mission — robot has Lidar → verify passes
// Run: spanda verify examples/showcase/hardware_verification/mission_with_lidar.sd --json

requires_hardware {
  sensors [ Lidar ];
}

hardware RoverV1 {
  cpu: CortexA78;
  memory: 4 GB;
  sensors [ Camera, Lidar, IMU ];
  actuators [ DifferentialDrive ];
  timing { min_period: 10 ms; }
}

robot ObstaclePatrol {
  sensor camera: Camera on "/camera";
  sensor lidar: Lidar on "/scan";
  actuator wheels: DifferentialDrive;

  behavior patrol() {
    loop every 100ms {
      let scan = lidar.read();
      let _ = scan;
      wheels.drive(linear: 0.2 m/s, angular: 0.0 rad/s);
    }
  }
}

deploy ObstaclePatrol to RoverV1;
